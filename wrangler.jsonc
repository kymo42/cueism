{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "cueism",
	"main": "./src/worker.ts",
	"compatibility_date": "2026-03-29",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "cueism-db",
			"database_id": "9af20805-6010-4474-9f3e-89c4c0563d72"
		},
	],
	"r2_buckets": [
		{
			"binding": "MEDIA",
			"bucket_name": "cueism-media",
		},
	],
	"observability": {
		"enabled": true
	}
}