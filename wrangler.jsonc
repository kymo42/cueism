{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "cueism",
	"main": "./src/worker.ts",
	"compatibility_date": "2026-03-29",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "cueism-db",
			// Run `wrangler d1 create cueism-db` and paste the ID here
		},
	],
	"r2_buckets": [
		{
			"binding": "MEDIA",
			"bucket_name": "cueism-media",
		},
	],
	"observability": {
		"enabled": true,
}