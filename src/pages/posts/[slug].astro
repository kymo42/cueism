---
import { getEmDashEntry, getEntryTerms, getSeoMeta } from "emdash";
import { Image, PortableText, WidgetArea } from "emdash/ui";
import Base from "../../layouts/Base.astro";
import { getPostDate, getPostHtmlContent, getPostImageSrc, getPostImageValue, hasPortableTextContent } from "../../utils/post-format";

const { slug } = Astro.params;

if (!slug) {
	return Astro.redirect("/404");
}

const { entry: post, cacheHint } = await getEmDashEntry("posts", slug);

if (!post) {
	return Astro.redirect("/404");
}

Astro.cache.set(cacheHint);

const seo = getSeoMeta(post, {
	siteTitle: "My Site",
	siteUrl: Astro.url.origin,
	path: `/posts/${slug}`,
});

const entryId = typeof post?.data?.id === "string" ? post.data.id : post.id;
const tags = await getEntryTerms("posts", entryId, "tag");
const categories = await getEntryTerms("posts", entryId, "category");

const imageSrc = getPostImageSrc(post);
const imageValue = getPostImageValue(post);
const htmlContent = getPostHtmlContent(post);
const publishedAt = getPostDate(post);
const title = typeof post.data.title === "string" ? post.data.title : "Post";
---

<Base
	title={seo.title}
	description={seo.description}
	canonical={seo.canonical}
	image={seo.ogImage}
	content={{ collection: "posts", id: entryId, slug }}
>
	<article>
		{imageValue ? (
			<div>
				{typeof imageValue === "object" ? (
					<Image image={imageValue} alt={title} style="width: 100%; border-radius: var(--radius-md);" />
				) : (
					imageSrc && <img src={imageSrc} alt={title} loading="eager" style="width: 100%; border-radius: var(--radius-md);" />
				)}
			</div>
		) : null}

		<h1>{post.data.title}</h1>

		{publishedAt && (
			<time datetime={publishedAt.toISOString()}>
				{publishedAt.toLocaleDateString("en-US", {
					year: "numeric",
					month: "long",
					day: "numeric",
				})}
			</time>
		)}

		{categories.length > 0 && (
			<p>{categories.map((category) => category.label).join(" • ")}</p>
		)}

		{hasPortableTextContent(post) ? (
			<div>
				<PortableText value={post.data.content} />
			</div>
		) : htmlContent ? (
			<div set:html={htmlContent} />
		) : null}

		{tags.length > 0 && <p>{tags.map((tag) => tag.label).join(" • ")}</p>}
	</article>

	<aside>
		<WidgetArea name="sidebar" />
	</aside>
</Base>
