---
import { getEmDashCollection } from "emdash";
import { Image, WidgetArea } from "emdash/ui";
import Base from "../../layouts/Base.astro";
import { getPriceRange } from "../../utils/products";

const { entries: products = [], cacheHint } = await getEmDashCollection("products", {
	orderBy: { published_at: "desc" },
}).catch(() => ({ entries: [], cacheHint: null }));

if (cacheHint) {
	Astro.cache.set(cacheHint);
}
---

<Base title="Shop | Cueism">
	<WidgetArea name="shop-top" />
	<section class="shop-grid">
		<div class="grid grid-auto">
			{
				products.length === 0 ? (
					<div class="card" style="grid-column: 1 / -1; text-align: center; padding: var(--spacing-lg);">
						<p style="margin-bottom: var(--spacing-sm);">No products available yet.</p>
						<a href="/_emdash/admin" class="btn btn-primary">Add products in Admin</a>
					</div>
				) : (
					products.map((product) => {
						const range = getPriceRange(product.data);
						const priceLabel =
							range.min === range.max
								? `$${range.min.toFixed(2)}`
								: `$${range.min.toFixed(2)} - $${range.max.toFixed(2)}`;

						const cardImage =
							product.data.featured_image ||
							(Array.isArray(product.data.gallery_images) ? product.data.gallery_images[0]?.image : undefined);

						return (
							<article class="product-card">
								<a href={`/shop/${product.slug || product.id}`} style="display: block;">
									{cardImage && (
										<div class="product-card-image">
											<Image image={cardImage} />
										</div>
									)}
									<div class="product-card-content">
										<h3>{product.data.title}</h3>
										<p class="product-card-price">{priceLabel}</p>
									</div>
								</a>
							</article>
						);
					})
				)
			}
		</div>
	</section>
	<WidgetArea name="shop-bottom" />
</Base>
