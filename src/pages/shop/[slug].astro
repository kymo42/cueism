---
import { getEmDashCollection } from "emdash";
import { Image, PortableText } from "emdash/ui";
import Base from "../../layouts/Base.astro";
import ProductPurchase from "../../components/ProductPurchase";
import {
	getBasePrice,
	getBaseStock,
	getBaseWeightGrams,
	getPriceRange,
	getProductVariants,
	getTrackStock,
} from "../../utils/products";

const { slug } = Astro.params;

const { entries: products } = await getEmDashCollection("products").catch(() => ({ entries: [] }));
const product = products.find((p: any) => p.slug === slug || p.id === slug);

if (!product) {
	return Astro.redirect("/404");
}

const featuredImage = product.data.featured_image as { src?: string; alt?: string } | undefined;
const variants = getProductVariants(product.data);
const priceRange = getPriceRange(product.data);
const basePrice = getBasePrice(product.data);
const baseStock = getBaseStock(product.data);
const baseWeightGrams = getBaseWeightGrams(product.data);
const trackStock = getTrackStock(product.data);

const hasTextOption = product.data.has_text_option === true;
const hasNfcOption = product.data.has_nfc_option === true;

const priceLabel =
	priceRange.min === priceRange.max
		? `$${(priceRange.min / 100).toFixed(2)}`
		: `$${(priceRange.min / 100).toFixed(2)} - $${(priceRange.max / 100).toFixed(2)}`;
---

<Base 
	title={`${product.data.title} | Cueism`} 
	description={product.data.excerpt || undefined}
>
	<div style="padding: var(--spacing-lg) 0;">
		<a href="/shop" style="color: var(--color-text-secondary); font-size: 0.875rem;">&larr; Back to Shop</a>
	</div>

	<div style="display: grid; grid-template-columns: 1fr 1fr; gap: var(--spacing-xl); margin-top: var(--spacing-md);">
		<div>
			{featuredImage ? (
				<div style="background: var(--color-bg-surface); border-radius: var(--radius-md); overflow: hidden;">
					<Image image={product.data.featured_image} />
				</div>
			) : (
				<div style="background: var(--color-bg-surface); border-radius: var(--radius-md); aspect-ratio: 1/1; display: flex; align-items: center; justify-content: center;">
					<p style="color: var(--color-text-tertiary);">No image</p>
				</div>
			)}
		</div>

		<div>
			<h1 style="font-size: 2rem; font-weight: 400; margin-bottom: var(--spacing-sm);">
				{product.data.title}
			</h1>
			
			<div style="font-size: 1.5rem; font-weight: 500; color: var(--color-text-primary); margin-bottom: var(--spacing-md);">
				{priceLabel}
			</div>

			<ProductPurchase
				client:load
				productId={product.id}
				slug={product.slug || product.id}
				title={product.data.title}
				image={featuredImage?.src}
				basePrice={basePrice}
				baseStock={baseStock}
				baseWeightGrams={baseWeightGrams}
				trackStock={trackStock}
				variants={variants}
				hasTextOption={hasTextOption}
				hasNfcOption={hasNfcOption}
			/>

			{product.data.content && (
				<div style="margin-top: var(--spacing-lg); padding-top: var(--spacing-lg); border-top: 1px solid var(--color-border-light);">
					<h2 style="font-size: 1rem; font-weight: 500; margin-bottom: var(--spacing-sm);">Description</h2>
					<div style="color: var(--color-text-secondary); line-height: 1.7;">
						<PortableText value={product.data.content} />
					</div>
				</div>
			)}
		</div>
	</div>

	<style>
		@media (max-width: 768px) {
			div[style*="grid-template-columns: 1fr 1fr"] {
				grid-template-columns: 1fr !important;
			}
		}
	</style>
</Base>
