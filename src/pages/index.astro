---
import { getEmDashCollection, getEmDashEntry } from "emdash";
import { WidgetArea } from "emdash/ui";
import Base from "../layouts/Base.astro";
import PostCardImage from "../components/PostCardImage";
import { getPostDate, getPostImageSrc, getPostIntro } from "../utils/post-format";

const { entries: posts, cacheHint } = await getEmDashCollection("posts", {
	orderBy: { published_at: "desc" },
});
Astro.cache.set(cacheHint);

// Use posts directly - getEmDashCollection should return full data
const normalizedPosts = posts;
---

<Base title="Cueism | Premium 3D Printed Accessories">
	<WidgetArea name="home-top" />
	<section class="hero">
		<h1>Precision. Crafted.</h1>
		<p>Australian-made accessories designed for those who appreciate the finer details of the game.</p>
		<a href="/shop" class="btn btn-primary">Shop the Collection</a>
	</section>

	<WidgetArea name="home-before-journal" />
	<section>
		<h2>Latest Journal</h2>
		<div class="grid grid-auto">
			{
				posts.length === 0 ? (
					<div class="card" style="grid-column: 1 / -1; text-align: center; padding: var(--spacing-lg);">
						<p style="margin-bottom: var(--spacing-sm);">No stories published yet.</p>
						<a href="/_emdash/admin/content/posts/new" class="btn btn-primary">Write the first entry</a>
					</div>
				) : (
					normalizedPosts.slice(0, 3).map((post) => {
						const intro = getPostIntro(post);
						const imageSrc = getPostImageSrc(post);
						const publishedAt = getPostDate(post);
						const title = typeof post.data.title === "string" ? post.data.title : "Post";
						return (
							<article class="card">
								<a href={`/posts/${post.id}`} style="display: block;">
									<PostCardImage src={imageSrc} alt={title} />
									<div class="card-content">
										<h3>{post.data.title}</h3>
										{intro && <p>{intro}</p>}
										{publishedAt && (
											<time datetime={publishedAt.toISOString()}>
												{publishedAt.toLocaleDateString("en-US", {
													year: "numeric",
													month: "long",
													day: "numeric",
												})}
											</time>
										)}
									</div>
								</a>
							</article>
						);
					})
				)
			}
		</div>
	</section>
	<WidgetArea name="home-after-journal" />
</Base>
