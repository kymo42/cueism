---
import { getEmDashCollection } from "emdash";
import Base from "../layouts/Base.astro";
import PostCardImage from "../components/PostCardImage";
import SavingsTicker from "../components/SavingsTicker.astro";
import PoolHero from "../components/PoolHero.astro";
import { getPostDate, getPostImageSrc, getPostIntro } from "../utils/post-format";

const { entries: posts, cacheHint } = await getEmDashCollection("posts", {
	orderBy: { created_at: "desc" },
});
Astro.cache.set(cacheHint);

const normalizedPosts = posts;
---

<Base
	title="Cueism | Rational 3D Printed Accessories"
	description="Australian-made, 3D-printed billiards and pool accessories — cue holders, chalk holders, racks and more. Printed to order from recycled and biodegradable materials."
	image="/og-image.png"
>
	<PoolHero>
		<section class="hero">
			<h1>Every Player of any species</h1>
			<p>Australian-made billiard accessories designed by and for the Pool player.</p>
			<a href="/products" class="btn btn-primary" data-astro-prefetch>Shop the Collection</a>
		</section>
	</PoolHero>

	<SavingsTicker />

	<section>
		<h2>Latest Posts</h2>
		<div class="grid grid-auto">
			{
				posts.length === 0 ? (
					<div class="card" style="grid-column: 1 / -1; text-align: center; padding: var(--spacing-lg);">
						<p style="margin-bottom: var(--spacing-sm);">No stories published yet.</p>
						<a href="/_emdash/admin/content/posts/new" class="btn btn-primary">Write the first entry</a>
					</div>
				) : (
					normalizedPosts.slice(0, 4).map((post) => {
						const intro = getPostIntro(post);
						const imageSrc = getPostImageSrc(post);
						const title = typeof post.data.title === "string" ? post.data.title : "Post";

						return (
							<article class="card">
								<a href={`/posts/${post.id}`} style="display: block;" data-astro-prefetch>
									<PostCardImage src={imageSrc} alt={title} />
									<div class="card-content">
										<h3>{post.data.title}</h3>
										{intro && <p>{intro}</p>}
									</div>
								</a>
							</article>
						);
					})
				)
			}
		</div>
	</section>
</Base>
