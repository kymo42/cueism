---
import { getEmDashCollection } from "emdash";
import { Image, WidgetArea } from "emdash/ui";
import Base from "../layouts/Base.astro";

const { entries: posts, cacheHint } = await getEmDashCollection("posts", {
	orderBy: { published_at: "desc" },
});
Astro.cache.set(cacheHint);

const getIntro = (post: any) => {
	if (typeof post.data.excerpt === "string" && post.data.excerpt.trim().length > 0) {
		return post.data.excerpt;
	}
	if (!Array.isArray(post.data.content)) return "";
	for (const block of post.data.content) {
		if (!Array.isArray(block?.children)) continue;
		const text = block.children.map((child: any) => child?.text || "").join(" ").trim();
		if (text.length > 0) {
			return text.length > 140 ? `${text.slice(0, 140)}...` : text;
		}
	}
	return "";
};
---

<Base title="Cueism | Premium 3D Printed Accessories">
	<WidgetArea name="home-top" />
	<section class="hero">
		<h1>Precision. Crafted.</h1>
		<p>Australian-made accessories designed for those who appreciate the finer details of the game.</p>
		<a href="/shop" class="btn btn-primary">Shop the Collection</a>
	</section>

	<WidgetArea name="home-before-journal" />
	<section>
		<h2>Latest Journal</h2>
		<div class="grid grid-auto">
			{
				posts.length === 0 ? (
					<div class="card" style="grid-column: 1 / -1; text-align: center; padding: var(--spacing-lg);">
						<p style="margin-bottom: var(--spacing-sm);">No stories published yet.</p>
						<a href="/_emdash/admin/content/posts/new" class="btn btn-primary">Write the first entry</a>
					</div>
				) : (
					posts.slice(0, 3).map((post) => {
						const intro = getIntro(post);
						return (
							<article class="card">
								<a href={`/posts/${post.id}`} style="display: block;">
									{post.data.featured_image && (
										<div class="card-image">
											<Image image={post.data.featured_image} />
										</div>
									)}
									<div class="card-content">
										<h3>{post.data.title}</h3>
										{intro && <p>{intro}</p>}
										{post.data.publishedAt && (
											<time datetime={post.data.publishedAt.toISOString()}>
												{post.data.publishedAt.toLocaleDateString("en-US", {
													year: "numeric",
													month: "long",
													day: "numeric",
												})}
											</time>
										)}
									</div>
								</a>
							</article>
						);
					})
				)
			}
		</div>
	</section>
	<WidgetArea name="home-after-journal" />
</Base>
