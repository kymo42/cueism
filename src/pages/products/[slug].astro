---
import { getEmDashEntry } from "emdash";
import { Image, PortableText } from "emdash/ui";
import Base from "../../layouts/Base.astro";
import ProductPurchase from "../../components/ProductPurchase";
import {
	getBasePrice,
	getBaseStock,
	getBaseWeightGrams,
	getPriceRange,
	getProductVariants,
	getTrackStock,
} from "../../utils/products";
import { buildProduct, stripToPlainText } from "../../utils/structured-data";
import { resolveMediaUrl } from "../../utils/post-format";
import {
	EMBEDDED_NFC_ONLY,
	INITIALS_OR_ICON_ONLY,
	LOGO_SURCHARGE,
	LOGO_SURCHARGE_BY_VARIANT,
} from "../../utils/surcharges";

const { slug } = Astro.params;

if (!slug) {
	return Astro.redirect("/404");
}

const { entry: product, cacheHint } = await getEmDashEntry("products", slug).catch(() => ({ entry: null, cacheHint: null }));

if (!product) {
	return Astro.redirect("/404");
}

if (cacheHint) {
	Astro.cache.set(cacheHint);
}

const featuredImage = product.data.featured_image as { src?: string; alt?: string } | undefined;
const galleryImages = Array.isArray(product.data.gallery_images)
	? product.data.gallery_images
			.map((item: any) => item?.image)
			.filter(Boolean)
	: [];
const displayImage = featuredImage || galleryImages[0];

// All images for the gallery: featured first, then gallery, de-duplicated.
const galleryAll = [featuredImage, ...galleryImages].filter(Boolean) as any[];
const seenImg = new Set<string>();
const galleryUnique = galleryAll.filter((img) => {
	const key = img?.meta?.storageKey || img?.src || img?.id || JSON.stringify(img);
	if (seenImg.has(key)) return false;
	seenImg.add(key);
	return true;
});
const displayImageUrl = resolveMediaUrl(displayImage);

const variants = getProductVariants(product.data);
const priceRange = getPriceRange(product.data);
const basePrice = getBasePrice(product.data);
const baseStock = getBaseStock(product.data);
const baseWeightGrams = getBaseWeightGrams(product.data);

// Products that do NOT offer text/NFC personalization or a body colour
// (e.g. chalk packs, which only have a quantity/pack option).
const NO_PERSONALIZATION = new Set(["chalkable"]);
const NO_COLOR = new Set<string>(["safe9"]);
const COLOUR_REQUEST = new Set(["chalkable"]);
const LOGO_UPLOAD = new Set(["chalkable"]);

// Products that display variants as radio buttons instead of a dropdown
const RADIO_VARIANTS = new Set(["safe9", "chalkable"]);
// Products that require an explicit variant pick before adding to cart.
const REQUIRE_VARIANT = new Set(["safe9"]);
// Products that track stock per-variant and show remaining counts.
const TRACK_STOCK = new Set(["safe9"]);
// EMBEDDED_NFC_ONLY, INITIALS_OR_ICON_ONLY, LOGO_SURCHARGE and
// LOGO_SURCHARGE_BY_VARIANT now live in utils/surcharges.ts so the cart price and
// the Stripe checkout amount share one source of truth.
const productKey = product.slug || product.id;
const requireVariant = REQUIRE_VARIANT.has(productKey);

// First colour variant drives the default gallery image for colour products.
// For require-variant products the gallery starts on slide 0 (featured image).
const defaultVariantColor = requireVariant ? "" : (variants[0]?.optionValue || "").toLowerCase();
const allowsPersonalization = !NO_PERSONALIZATION.has(productKey);
const hasTextOption = allowsPersonalization;
const hasNfcOption = allowsPersonalization || EMBEDDED_NFC_ONLY.has(productKey);
const showColor = !NO_COLOR.has(productKey);
const allowColourRequest = COLOUR_REQUEST.has(productKey);
const allowLogoUpload = LOGO_UPLOAD.has(productKey);
const embeddedNfcOnly = EMBEDDED_NFC_ONLY.has(productKey);
const useRadioVariants = RADIO_VARIANTS.has(productKey);
const logoSurcharge = LOGO_SURCHARGE[productKey] || 0;
const logoSurchargeByVariant = LOGO_SURCHARGE_BY_VARIANT[productKey];
const initialsOrIconOnly = INITIALS_OR_ICON_ONLY.has(productKey);
const allowFaceUpload = productKey === "racksafe9";
const trackStock = getTrackStock(product.data) || TRACK_STOCK.has(productKey);

// Per-product "Nogenn colour" add-on (the rubber grip), mirrored from the
// legacy WordPress product options. Keyed by slug until colours move into the CMS.
const NOGENN_COLOURS_BY_SLUG: Record<string, string[]> = {
	cheatstick: ["white", "black", "yellow", "blue"],
};
const nogennColours = NOGENN_COLOURS_BY_SLUG[product.slug || product.id] ?? [];

const priceLabel =
	priceRange.min === priceRange.max
		? `$${priceRange.min.toFixed(2)}`
		: `$${priceRange.min.toFixed(2)} - $${priceRange.max.toFixed(2)}`;

const metaDescription = stripToPlainText(product.data.excerpt ?? product.data.description) || undefined;
const productJsonLd = buildProduct(product, Astro.url.origin);
---

<Base
	title={`${product.data.title} | Cueism`}
	description={metaDescription}
	ogType="product"
	jsonLd={productJsonLd}
>
	<div style="padding: var(--spacing-lg) 0;">
		<a href="/products" style="color: var(--color-text-secondary); font-size: 0.875rem;">&larr; Back to Shop</a>
	</div>

	<div style="display: grid; grid-template-columns: 1fr 1fr; gap: var(--spacing-xl); margin-top: var(--spacing-md);">
		<div>
			{galleryUnique.length > 0 ? (
				<div class="product-gallery" data-default-color={defaultVariantColor}>
					<div class="product-gallery-main">
						{galleryUnique.map((image: any, i: number) => {
							const src = image?.src || image?.meta?.storageKey || "";
							const isColorsImage = src.includes("racksafe9_colors.jpg");
							return (
								<div
									class={`product-gallery-slide${isColorsImage ? " colors-group-image" : ""}`}
									data-gallery-index={i}
									data-color={image?.color}
									style={`background: var(--color-bg-surface); border-radius: var(--radius-md); overflow: hidden;${i === 0 ? "" : " display: none;"}`}
								>
									<Image image={image} />
								</div>
							);
						})}
					</div>
					{galleryUnique.length > 1 && (
						<div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(64px, 1fr)); gap: 0.5rem; margin-top: 0.75rem;">
							{galleryUnique.map((image: any, i: number) => (
								<button
									type="button"
									class="product-gallery-thumb"
									data-gallery-index={i}
									data-color={image?.color}
									aria-label={`View image ${i + 1}`}
									style="border: 1px solid var(--color-border-light); border-radius: var(--radius-sm); overflow: hidden; padding: 0; background: none; cursor: pointer; line-height: 0;"
								>
									<Image image={image} />
								</button>
							))}
						</div>
					)}
				</div>
			) : (
				<div style="background: var(--color-bg-surface); border-radius: var(--radius-md); aspect-ratio: 1/1; display: flex; align-items: center; justify-content: center;">
					<p style="color: var(--color-text-tertiary);">No image</p>
				</div>
			)}
		</div>

		<div>
			<h1 style="font-size: 2rem; font-weight: 400; margin-bottom: var(--spacing-sm);">
				{product.data.title}
			</h1>
			
			<div style="font-size: 1.5rem; font-weight: 500; color: var(--color-text-primary); margin-bottom: var(--spacing-md);">
				{priceLabel}
			</div>

			<ProductPurchase
				client:load
				productId={product.id}
				slug={product.slug || product.id}
				title={product.data.title}
				image={displayImageUrl}
				basePrice={basePrice}
				baseStock={baseStock}
				baseWeightGrams={baseWeightGrams}
				trackStock={trackStock}
				variants={variants}
				hasTextOption={hasTextOption}
				hasNfcOption={hasNfcOption}
				nogennColours={nogennColours}
				showColor={showColor}
				allowColourRequest={allowColourRequest}
				allowLogoUpload={allowLogoUpload}
				embeddedNfcOnly={embeddedNfcOnly}
				useRadioVariants={useRadioVariants}
				logoSurcharge={logoSurcharge}
				logoSurchargeByVariant={logoSurchargeByVariant}
				initialsOrIconOnly={initialsOrIconOnly}
				allowFaceUpload={allowFaceUpload}
				requireVariant={requireVariant}
			/>
		</div>
	</div>

	{product.data.content && (
		<div style="margin-top: var(--spacing-lg); padding-top: var(--spacing-lg); border-top: 1px solid var(--color-border-light); max-width: 840px;">
			<h2 style="font-size: 1rem; font-weight: 500; margin-bottom: var(--spacing-sm);">Description</h2>
			<div style="color: var(--color-text-secondary); line-height: 1.7;">
				<PortableText value={product.data.content} />
			</div>
		</div>
	)}

	<style>
		@media (max-width: 768px) {
			div[style*="grid-template-columns: 1fr 1fr"] {
				grid-template-columns: 1fr !important;
			}
		}
		.product-gallery-main {
			width: 100%;
			aspect-ratio: 1/1; /* Square */
			border-radius: var(--radius-md);
			overflow: hidden;
			background: var(--color-bg-surface);
		}
		.product-gallery-slide {
			width: 100%;
			height: 100%;
		}
		.product-gallery-slide img,
		.product-gallery-slide :global(img) {
			width: 100% !important;
			height: 100% !important;
			object-fit: cover !important;
		}
		.product-gallery-thumb {
			width: 100%;
			aspect-ratio: 3/4; /* Portrait */
			display: flex;
			align-items: center;
			justify-content: center;
			background: var(--color-bg-surface);
			overflow: hidden;
		}
		.product-gallery-thumb img,
		.product-gallery-thumb :global(img) {
			width: 100% !important;
			height: 100% !important;
			object-fit: cover !important;
		}
		.product-gallery-thumb {
			transition: outline-color 0.15s ease;
			outline: 2px solid transparent;
			outline-offset: -2px;
		}
		.product-gallery-thumb[aria-current="true"] {
			outline-color: var(--color-accent);
		}
		.product-gallery-thumb:hover {
			outline-color: var(--color-border);
		}
	</style>

	<script>
		function initProductGalleries() {
			document.querySelectorAll(".product-gallery").forEach((gallery) => {
				if (gallery.dataset.galleryReady === "1") return; // avoid double-binding
				gallery.dataset.galleryReady = "1";

				const slides = gallery.querySelectorAll(".product-gallery-slide");
				const thumbs = gallery.querySelectorAll(".product-gallery-thumb");
				if (!thumbs.length) return;

				const show = (index) => {
					slides.forEach((s) => {
						s.style.display = s.dataset.galleryIndex === index ? "" : "none";
					});
					thumbs.forEach((t) => {
						t.setAttribute("aria-current", t.dataset.galleryIndex === index ? "true" : "false");
					});
				};

				// Find the slide tagged with a given colour (a slide may serve several
				// colours via a comma-separated data-color, e.g. "black,white").
				const findColorIndex = (color) => {
					if (!color) return null;
					const match = Array.from(slides).find((s) =>
						(s.dataset.color || "").split(",").includes(color)
					);
					return match ? match.dataset.galleryIndex || "0" : null;
				};

				// Let the product form (React island) drive the gallery by colour.
				gallery._showColor = (color) => {
					const index = findColorIndex(color);
					if (index !== null) show(index);
				};

				thumbs.forEach((thumb) => {
					thumb.addEventListener("click", () => show(thumb.dataset.galleryIndex || "0"));
				});

				// Default to the first colour variant's image when one matches.
				const defaultIndex = findColorIndex(gallery.dataset.defaultColor);
				show(defaultIndex !== null ? defaultIndex : "0");
			});
		}

		function showGalleryColor(color) {
			document.querySelectorAll(".product-gallery").forEach((gallery) => {
				if (typeof gallery._showColor === "function") gallery._showColor(color);
			});
		}

		// Run now (covers direct loads) and after each view-transition navigation.
		initProductGalleries();
		document.addEventListener("astro:page-load", initProductGalleries);
		window.addEventListener("cueism:variant-color", (e) => showGalleryColor(e.detail && e.detail.color));
	</script>
</Base>
