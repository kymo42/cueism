---
import { getTerm, getEmDashCollection, getEmDashEntry } from "emdash";
import Base from "../../layouts/Base.astro";
import PostCardImage from "../../components/PostCardImage";
import { getPostDate, getPostImageSrc, getPostIntro } from "../../utils/post-format";

const { slug } = Astro.params;
const term = slug ? await getTerm("category", slug) : null;

if (!term) {
	return Astro.redirect("/404");
}

const { entries: posts } = await getEmDashCollection("posts", {
	where: { category: term.slug },
	orderBy: { published_at: "desc" },
});

const normalizedPosts = await Promise.all(
	posts.map(async (post) => {
		// Try slug first, then ID
		const identifiers = [post.slug, post.id].filter(Boolean);
		let fullPost = null;
		for (const identifier of identifiers) {
			const result = await getEmDashEntry("posts", identifier).catch(() => null);
			if (result?.entry) {
				fullPost = result.entry;
				break;
			}
		}
		return fullPost || post;
	}),
);
---

<Base title={`${term.label} posts`} description={`Posts in ${term.label}`}>
	<h1>{term.label}</h1>
	<p>{posts.length} {posts.length === 1 ? "post" : "posts"}</p>

	{
		posts.length === 0 ? (
			<p>No posts in this category yet.</p>
		) : (
			<div class="grid grid-auto">
				{normalizedPosts.map((post) => {
					const imageSrc = getPostImageSrc(post);
					const intro = getPostIntro(post);
					const publishedAt = getPostDate(post);
					const title = typeof post.data.title === "string" ? post.data.title : "Post";
					return (
						<article class="card">
							<a href={`/posts/${post.id}`} style="display: block;">
								<PostCardImage src={imageSrc} alt={title} />
								<div class="card-content">
									<h3>{post.data.title}</h3>
									{intro && <p>{intro}</p>}
									{publishedAt && (
										<time datetime={publishedAt.toISOString()}>
											{publishedAt.toLocaleDateString("en-US", {
												year: "numeric",
												month: "long",
												day: "numeric",
											})}
										</time>
									)}
								</div>
							</a>
						</article>
					);
				})}
			</div>
		)
	}
</Base>
