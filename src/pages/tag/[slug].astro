---
import { getTerm, getEmDashCollection } from "emdash";
import Base from "../../layouts/Base.astro";
import PostCardImage from "../../components/PostCardImage";
import { getPostDate, getPostImageSrc, getPostIntro } from "../../utils/post-format";

const { slug } = Astro.params;
const term = slug ? await getTerm("tag", slug) : null;

if (!term) {
	return Astro.redirect("/404");
}

const { entries: posts } = await getEmDashCollection("posts", {
	where: { tag: term.slug },
	orderBy: { published_at: "desc" },
});

const normalizedPosts = posts;
---

<Base
	title={`Posts tagged "${term.label}"`}
	description={`Posts tagged ${term.label}`}
>
	<h1>Tag: {term.label}</h1>
	<p>{posts.length} {posts.length === 1 ? "post" : "posts"}</p>

	{
		posts.length === 0 ? (
			<p>No posts with this tag yet.</p>
		) : (
			<div class="grid grid-auto">
				{normalizedPosts.map((post) => {
					const imageSrc = getPostImageSrc(post);
					const intro = getPostIntro(post);
					const publishedAt = getPostDate(post);
					const title = typeof post.data.title === "string" ? post.data.title : "Post";
					return (
						<article class="card">
							<a href={`/posts/${post.id}`} style="display: block;" data-astro-prefetch>
								<PostCardImage src={imageSrc} alt={title} />
								<div class="card-content">
									<h3>{post.data.title}</h3>
									{intro && <p>{intro}</p>}
									{publishedAt && (
										<time datetime={publishedAt.toISOString()}>
											{publishedAt.toLocaleDateString("en-US", {
												year: "numeric",
												month: "long",
												day: "numeric",
											})}
										</time>
									)}
								</div>
							</a>
						</article>
					);
				})}
			</div>
		)
	}
</Base>
