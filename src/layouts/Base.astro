---
import { ClientRouter } from "astro:transitions";
import { getMenu } from "emdash";
import {
	EmDashHead,
	EmDashBodyStart,
	EmDashBodyEnd,
} from "emdash/ui";
import { createPublicPageContext, safeJsonLdSerialize } from "emdash/page";
import CartFlyout from "../components/CartFlyout";
import CartToggle from "../components/CartToggle";
import { buildOrganization, buildWebSite } from "../utils/structured-data";
import "../styles/global.css";

interface Props {
	title: string;
	description?: string | null;
	image?: string | null;
	canonical?: string | null;
	content?: { collection: string; id: string; slug?: string | null };
	/** Open Graph type, e.g. "product" or "article". Defaults to "website". */
	ogType?: string;
	/** Page-specific JSON-LD graph(s) to render alongside the sitewide Organization. */
	jsonLd?: Record<string, unknown> | Record<string, unknown>[] | null;
}

const { title, description, image, canonical, content, ogType, jsonLd } = Astro.props;

const menu = await getMenu("primary");

// Open Graph images must be absolute URLs; absolutize root-relative paths.
const resolvedImage = image?.startsWith("/") ? new URL(image, Astro.url.origin).href : image;

const pageCtx = createPublicPageContext({
	Astro,
	kind: content ? "content" : "custom",
	pageType: ogType ?? "website",
	title,
	description,
	canonical,
	image: resolvedImage,
	content,
});

const siteJsonLd = [buildOrganization(Astro.url.origin), buildWebSite(Astro.url.origin)];
const extraJsonLd = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];

// GA4 measurement ID per host — cueism.com and www.cueism.com are tracked as separate properties.
const GA_MEASUREMENT_IDS: Record<string, string> = {
	"cueism.com": "G-Q1R9XBJWEX",
	"www.cueism.com": "G-CJHZQ7LR51",
};
const gaMeasurementId = GA_MEASUREMENT_IDS[Astro.url.hostname] ?? GA_MEASUREMENT_IDS["cueism.com"];
---

<!doctype html>
<html lang="en">
	<head>
		<script async src={`https://www.googletagmanager.com/gtag/js?id=${gaMeasurementId}`}></script>
		<script is:inline define:vars={{ gaMeasurementId }}>
			window.dataLayer = window.dataLayer || [];
			function gtag() {
				dataLayer.push(arguments);
			}
			gtag("js", new Date());
			gtag("config", gaMeasurementId);
		</script>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/x-icon" href="/favicon.ico" />
		<title>{title}</title>
		{description && <meta name="description" content={description} />}
		{canonical && <link rel="canonical" href={canonical} />}
		<EmDashHead page={pageCtx} />
		{siteJsonLd.map((graph) => (
			<script type="application/ld+json" set:html={safeJsonLdSerialize(graph)} />
		))}
		{extraJsonLd.map((graph) => (
			<script type="application/ld+json" set:html={safeJsonLdSerialize(graph)} />
		))}
	</head>
	<body>
		<ClientRouter />
		<EmDashBodyStart page={pageCtx} />

		<header>
			<nav>
				<a href="/" class="logo" data-astro-prefetch>cueism</a>
				<input type="checkbox" id="nav-toggle" class="nav-toggle" />
				<label for="nav-toggle" class="nav-hamburger" aria-label="Toggle menu">
					<span></span><span></span><span></span>
				</label>
				<div class="nav-links">
					{menu?.items.map((item) => (
						<a href={item.url} target={item.target} data-astro-prefetch>
							{item.label}
						</a>
					))}
				</div>
				<CartToggle client:idle />
			</nav>
		</header>

		<main>
			<slot />
		</main>

		<footer>
			<nav class="footer-legal" aria-label="Legal">
				<a href="/about">About</a>
				<a href="/privacy-policy-2">Privacy Policy</a>
				<a href="/cookie-policy">Cookie Policy</a>
				<a href="/refund_returns">Returns &amp; Refunds</a>
				<a href="/flog">Flog</a>
			</nav>
			<p>&copy; {new Date().getFullYear()} cueism. All rights reserved.</p>
		</footer>

		<CartFlyout client:idle />
		<EmDashBodyEnd page={pageCtx} />
	</body>
</html>
