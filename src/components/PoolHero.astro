---
/**
 * Full-bleed canvas pool-ball animation behind slotted hero content.
 * Canvas extends 1.5x the content height and fades out at the bottom,
 * so balls drift under the following content with no visible boundary.
 */
---

<div class="pool-hero">
	<canvas class="pool-hero-canvas" aria-hidden="true"></canvas>
	<div class="pool-hero-content"><slot /></div>
</div>

<style>
	.pool-hero {
		position: relative;
		width: 100vw;
		margin-left: calc(50% - 50vw);
	}

	.pool-hero-canvas {
		position: absolute;
		/* Stretch up over main's top padding (--spacing-lg) so balls run flush to
		   the header; the short top fade dissolves them instead of a hard clip
		   line. The engine measures this box directly, so CSS alone owns the
		   canvas geometry. */
		top: calc(-1 * var(--spacing-lg));
		left: 0;
		width: 100%;
		height: calc(150% + var(--spacing-lg));
		z-index: -1;
		pointer-events: none;
		-webkit-mask-image: linear-gradient(to bottom, transparent 0, black 2.5rem, black 75%, transparent 100%);
		mask-image: linear-gradient(to bottom, transparent 0, black 2.5rem, black 75%, transparent 100%);
	}

	.pool-hero-content {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 var(--spacing-md);
	}
</style>

<script>
	import { initPoolHero, type PoolHeroHandle } from "../scripts/pool-hero";

	let handle: PoolHeroHandle | null = null;

	function setup() {
		handle?.destroy();
		handle = null;
		const canvas = document.querySelector<HTMLCanvasElement>("canvas.pool-hero-canvas");
		if (canvas) handle = initPoolHero(canvas);
	}

	document.addEventListener("astro:page-load", setup);
	document.addEventListener("astro:before-swap", () => {
		handle?.destroy();
		handle = null;
	});
</script>
