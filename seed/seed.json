					"excerpt": "Filler's Historic Vegas Double, WNT's US Expansion, and a Fond Farewell",
					"content": [
						{ "_type": "block", "style": "h1", "children": [{ "_type": "span", "text": "Filler's Historic Vegas Double, WNT's US Expansion, and a Fond Farewell" }] },
						{ "_type": "block", "style": "h2", "children": [{ "_type": "span", "text": "Joshua Filler Achieves Historic Double at the Las Vegas Festival" }] },
						{ "_type": "block", "style": "normal", "children": [{ "_type": "span", "text": "Germany's own Joshua Filler absolutely dominated the felt to claim the prestigious 2026 Las Vegas Men's Open title. This wasn't just any win; Filler achieved a historic double in Las Vegas, a feat that will undoubtedly be etched into the annals of pool history." }] },
						{ "_type": "block", "style": "h2", "children": [{ "_type": "span", "text": "World Nineball Tour Expands US Footprint with Inaugural Arizona Open" }] },
						{ "_type": "block", "style": "normal", "children": [{ "_type": "span", "text": "The World Nineball Tour (WNT) has officially announced its expansion into the USA with the brand-new Arizona Open Pool Championship, slated for August 13-16, 2026." }] },
						{ "_type": "block", "style": "h2", "children": [{ "_type": "span", "text": "Remembering a Snooker Icon: Sindhu Pulsirivong Passes Away" }] },
						{ "_type": "block", "style": "normal", "children": [{ "_type": "span", "text": "The global billiards family is mourning the loss of a truly significant figure in the snooker world, Sindhu Pulsirivong, whose profound contributions to the sport left an indelible mark on its development and governance." }] }
					]
				},
