{
	"$schema": "https://emdashcms.com/seed.schema.json",
	"version": "1",
	"meta": {
		"name": "Cueism",
		"description": "Premium 3D-printed pool accessories - Made in Australia",
		"author": "Major155ues"
	},

	"settings": {
		"title": "Cueism",
		"tagline": "Premium 3D-Printed Pool Accessories"
	},

	"collections": [
		{
			"slug": "posts",
			"label": "Posts",
			"labelSingular": "Post",
			"supports": ["drafts", "revisions", "search", "seo"],
			"fields": [
				{ "slug": "title", "label": "Title", "type": "string", "required": true, "searchable": true },
				{ "slug": "featured_image", "label": "Featured Image", "type": "image" },
				{ "slug": "content", "label": "Content", "type": "portableText", "searchable": true },
				{ "slug": "excerpt", "label": "Excerpt", "type": "text" }
			]
		},
		{
			"slug": "products",
			"label": "Products",
			"labelSingular": "Product",
			"supports": ["drafts", "search", "seo"],
			"fields": [
				{ "slug": "title", "label": "Title", "type": "string", "required": true },
				{ "slug": "sku", "label": "SKU", "type": "string" },
				{ "slug": "price", "label": "Base Price (Cents)", "type": "number", "required": true },
				{ "slug": "compare_at_price", "label": "Compare At Price (Cents)", "type": "number" },
				{ "slug": "track_stock", "label": "Track Stock", "type": "boolean" },
				{ "slug": "stock", "label": "Base Stock", "type": "integer" },
				{ "slug": "weight_grams", "label": "Base Weight (Grams)", "type": "integer" },
				{ "slug": "inventory_count", "label": "Legacy Inventory", "type": "number" },
				{ "slug": "status", "label": "Status", "type": "select", "validation": { "options": ["active", "draft", "discontinued"] } },
				{ "slug": "variants", "label": "Variants", "type": "repeater", "validation": {
					"subFields": [
						{ "slug": "id", "type": "string", "label": "Variant ID" },
						{ "slug": "label", "type": "string", "label": "Label", "required": true },
						{ "slug": "option_group", "type": "string", "label": "Option Group" },
						{ "slug": "option_value", "type": "string", "label": "Option Value" },
						{ "slug": "price", "type": "number", "label": "Price (Cents)", "required": true },
						{ "slug": "stock", "type": "integer", "label": "Stock" },
						{ "slug": "weight_grams", "type": "integer", "label": "Weight (Grams)" },
						{ "slug": "sku", "type": "string", "label": "SKU" },
						{ "slug": "enabled", "type": "boolean", "label": "Enabled" }
					]
				}},
				{ "slug": "featured_image", "label": "Primary Image", "type": "image" },
				{ "slug": "gallery_images", "label": "Gallery Images", "type": "repeater", "validation": {
					"subFields": [
						{ "slug": "image", "type": "image", "label": "Image", "required": true },
						{ "slug": "caption", "type": "string", "label": "Caption" }
					]
				}},
				{ "slug": "excerpt", "label": "Short Description", "type": "text" },
				{ "slug": "content", "label": "Full Description", "type": "portableText" },
				{ "slug": "has_text_option", "label": "Enable Text Personalization", "type": "boolean" },
				{ "slug": "has_nfc_option", "label": "Enable NFC Personalization", "type": "boolean" }
			]
		},
		{
			"slug": "pages",
			"label": "Pages",
			"labelSingular": "Page",
			"supports": ["drafts", "revisions", "search"],
			"fields": [
				{ "slug": "title", "label": "Title", "type": "string", "required": true, "searchable": true },
				{ "slug": "content", "label": "Content", "type": "portableText", "searchable": true }
			]
		},
		{
			"slug": "comp_winners",
			"label": "Comp Winners",
			"labelSingular": "Comp Winner",
			"supports": ["drafts", "search"],
			"fields": [
				{ "slug": "winner_name", "label": "Winner Name", "type": "string", "required": true, "searchable": true },
				{ "slug": "tournament", "label": "Tournament Name", "type": "string", "required": true },
				{ "slug": "venue", "label": "Venue", "type": "string" },
				{ "slug": "location", "label": "Location", "type": "string" },
				{ "slug": "game_type", "label": "Game Type", "type": "select", "validation": { "options": ["8-ball", "9-ball", "10-ball", "snooker", "heyball", "other"] } },
				{ "slug": "date", "label": "Date", "type": "string" },
				{ "slug": "notes", "label": "Notes", "type": "text" },
				{ "slug": "submitted_by", "label": "Submitted By", "type": "string" },
				{ "slug": "featured_image", "label": "Photo", "type": "image" }
			]
		}
	],

	"taxonomies": [
		{
			"name": "category",
			"label": "Categories",
			"labelSingular": "Category",
			"hierarchical": true,
			"collections": ["posts"],
			"terms": [
				{ "slug": "news", "label": "News" },
				{ "slug": "monthly-roundup", "label": "Monthly Roundup" },
				{ "slug": "weekly-spotlight", "label": "Weekly Spotlight" },
				{ "slug": "product-updates", "label": "Product Updates" }
			]
		},
		{
			"name": "tag",
			"label": "Tags",
			"labelSingular": "Tag",
			"hierarchical": false,
			"collections": ["posts"],
			"terms": [
				{ "slug": "wpa", "label": "WPA" },
				{ "slug": "wpbsa", "label": "WPBSA" },
				{ "slug": "snooker", "label": "Snooker" },
				{ "slug": "pool", "label": "Pool" },
				{ "slug": "heyball", "label": "Heyball" },
				{ "slug": "championship", "label": "Championship" }
			]
		},
		{
			"name": "product_category",
			"label": "Product Categories",
			"labelSingular": "Product Category",
			"hierarchical": true,
			"collections": ["products"],
			"terms": [
				{ "slug": "chalk", "label": "Chalk" },
				{ "slug": "racking", "label": "Racking" },
				{ "slug": "cueing", "label": "Cueing" },
				{ "slug": "gift-cards", "label": "Gift Cards" }
			]
		}
	],

	"menus": [
		{
			"name": "primary",
			"label": "Primary Navigation",
			"items": [
				{ "type": "custom", "label": "Home", "url": "/" },
				{ "type": "custom", "label": "Shop", "url": "/shop" },
				{ "type": "custom", "label": "News", "url": "/posts" },
				{ "type": "custom", "label": "Comp Winners", "url": "/comp-winners" },
				{ "type": "custom", "label": "Submit Result", "url": "/submit-tournament" },
				{ "type": "custom", "label": "About", "url": "/about" }
			]
		}
	],

	"widgetAreas": [
		{ "name": "sidebar", "label": "Sidebar", "description": "Sidebar widget area", "widgets": [
			{ "type": "component", "componentId": "core:search", "title": "Search" },
			{ "type": "component", "componentId": "core:categories", "title": "Categories" },
			{ "type": "component", "componentId": "core:recent-posts", "title": "Recent Posts", "settings": { "count": 5 } }
		]},
		{ "name": "global-top", "label": "Global Top", "description": "Widgets shown above page content", "widgets": [] },
		{ "name": "global-bottom", "label": "Global Bottom", "description": "Widgets shown below page content", "widgets": [] },
		{ "name": "footer", "label": "Footer", "description": "Footer widget area", "widgets": [] },
		{ "name": "shop-top", "label": "Shop Top", "description": "Shop widgets before product grid", "widgets": [] },
		{ "name": "shop-bottom", "label": "Shop Bottom", "description": "Shop widgets below product grid", "widgets": [] }
	],

	"content": {
		"pages": [
			{
				"id": "about",
				"slug": "about",
				"status": "published",
				"data": {
					"title": "About Cueism",
					"content": [
						{ "_type": "block", "style": "h1", "children": [{ "_type": "span", "text": "About Cueism" }] },
						{ "_type": "block", "style": "normal", "children": [{ "_type": "span", "text": "Cueism creates premium 3D-printed pool accessories in Sydney, Australia. Our products are crafted from recycled rPET and biodegradable PLA+ thermoplastics — almost entirely free from virgin fossil resources." }] },
						{ "_type": "block", "style": "h2", "children": [{ "_type": "span", "text": "What We Make" }] },
						{ "_type": "block", "style": "normal", "children": [{ "_type": "span", "text": "From chalk protectors that keep your premium chalk pristine, to rack safes that preserve your Magick Rack for life, to mini-butts that help you stretch on a 9ft table — every product is designed with sustainability, functionality, and personalization in mind." }] },
						{ "_type": "block", "style": "h2", "children": [{ "_type": "span", "text": "Smart Personalization" }] },
						{ "_type": "block", "style": "normal", "children": [{ "_type": "span", "text": "Most of our products support RFID/NFC chip embedding, custom text engraving, and icon selection. Store your digital contact info so if you leave your gear at the venue, it finds its way back to you." }] },
						{ "_type": "block", "style": "h2", "children": [{ "_type": "span", "text": "Locally Made" }] },
						{ "_type": "block", "style": "normal", "children": [{ "_type": "span", "text": "Every piece is designed, prototyped, and 3D-printed right here in Sydney. This ensures top-tier quality control, rapid iteration, and support for local manufacturing." }] }
					]
				}
			},
			{
				"id": "submit-tournament",
				"slug": "submit-tournament",
				"status": "published",
				"data": {
					"title": "Submit Your Tournament Result",
					"content": [
						{ "_type": "block", "style": "normal", "children": [{ "_type": "span", "text": "Won a local tournament? Know someone who dominated their pub league? We want to celebrate grassroots pool players! Submit your result and we'll feature it in our Weekly Pool Spotlight." }] },
						{ "_type": "block", "style": "h2", "children": [{ "_type": "span", "text": "How to Submit" }] },
						{ "_type": "block", "style": "normal", "children": [{ "_type": "span", "text": "Send us an email at 42155ues@gmail.com or message us on social media with: tournament name, venue, winner, game type, and any photos. We'll handle the rest!" }] }
					]
				}
			},
			{
				"id": "comp-winners",
				"slug": "comp-winners",
				"status": "published",
				"data": {
					"title": "Pool Comp Winners Tracker",
					"content": [
						{ "_type": "block", "style": "normal", "children": [{ "_type": "span", "text": "A living record of pool competition winners from around the world. From pub leagues to regional championships — every winner matters." }] }
					]
				}
			}
		],
