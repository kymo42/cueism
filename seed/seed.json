				"data": {
					"title": "Monthly Billiard News Round-Up April",
					"excerpt": "Billiard World Rallies: Champions Crowned, Legends Honored, and Global Showdowns Electrify the Tables!",
					"content": [
						{ "_type": "block", "style": "h1", "children": [{ "_type": "span", "text": "Billiard World Rallies: Champions Crowned, Legends Honored, and Global Showdowns Electrify the Tables!" }] },
						{ "_type": "block", "style": "h2", "children": [{ "_type": "span", "text": "WPA Honors Its Best: Jasmin Ouschan and Alexander Kazakis Crowned Athletes of the Year 2025" }] },
						{ "_type": "block", "style": "normal", "children": [{ "_type": "span", "text": "The World Pool-Billiard Association (WPA) has proudly announced Jasmin Ouschan and Alexander Kazakis as their Athletes of the Year for 2025. This esteemed accolade highlights their unwavering dedication, consistent excellence, and inspiring sportsmanship throughout the past year." }] },
						{ "_type": "block", "style": "h2", "children": [{ "_type": "span", "text": "Ng On Yee Achieves Historic British Open Hat-Trick!" }] },
						{ "_type": "block", "style": "normal", "children": [{ "_type": "span", "text": "Hong Kong's snooker sensation, Ng On Yee, has once again etched her name in the record books. She completed a phenomenal British Open Hat-Trick, securing her third consecutive title at the prestigious event held at the Landywood Snooker Club." }] },
						{ "_type": "block", "style": "h2", "children": [{ "_type": "span", "text": "Global Billiard Festivals Ignite with World Championships and Circuit Triumphs" }] },
						{ "_type": "block", "style": "normal", "children": [{ "_type": "span", "text": "The highly anticipated Predator Pro Billiard Series Las Vegas Festival is building incredible momentum, featuring the commencement of the Predator WPA Teams World 10-Ball Championship." }] }
					]
