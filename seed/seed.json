{
	"$schema": "https://emdashcms.com/seed.schema.json",
	"version": "1",
	"meta": {
		"name": "Starter",
		"description": "A minimal EmDash starter with posts and pages",
		"author": "EmDash"
	},

	"settings": {
		"title": "My Site",
		"tagline": "Built with EmDash"
	},

	"collections": [
		{
			"slug": "posts",
			"label": "Posts",
			"labelSingular": "Post",
			"supports": ["drafts", "revisions", "search", "seo"],
			"fields": [
				{
					"slug": "title",
					"label": "Title",
					"type": "string",
					"required": true,
					"searchable": true
				},
				{
					"slug": "featured_image",
					"label": "Featured Image",
					"type": "image"
				},
				{
					"slug": "content",
					"label": "Content",
					"type": "portableText",
					"searchable": true
				},
				{
					"slug": "excerpt",
					"label": "Excerpt",
					"type": "text"
				}
			]
		},
		{
			"slug": "products",
			"label": "Products",
			"labelSingular": "Product",
			"supports": ["drafts", "search", "seo"],
			"fields": [
				{
					"slug": "title",
					"label": "Title",
					"type": "string",
					"required": true
				},
				{
					"slug": "sku",
					"label": "SKU",
					"type": "string"
				},
				{
					"slug": "price",
					"label": "Base Price (Cents)",
					"type": "number",
					"required": true
				},
				{
					"slug": "compare_at_price",
					"label": "Compare At Price (Cents)",
					"type": "number"
				},
				{
					"slug": "track_stock",
					"label": "Track Stock",
					"type": "boolean"
				},
				{
					"slug": "stock",
					"label": "Base Stock",
					"type": "integer"
				},
				{
					"slug": "weight_grams",
					"label": "Base Weight (Grams)",
					"type": "integer"
				},
				{
					"slug": "inventory_count",
					"label": "Legacy Inventory",
					"type": "number"
				},
				{
					"slug": "status",
					"label": "Status",
					"type": "select",
					"validation": {
						"options": ["active", "draft", "discontinued"]
					}
				},
				{
					"slug": "variants",
					"label": "Variants",
					"type": "repeater",
					"validation": {
						"subFields": [
							{ "slug": "id", "type": "string", "label": "Variant ID" },
							{ "slug": "label", "type": "string", "label": "Label", "required": true },
							{ "slug": "option_group", "type": "string", "label": "Option Group" },
							{ "slug": "option_value", "type": "string", "label": "Option Value" },
							{ "slug": "price", "type": "number", "label": "Price (Cents)", "required": true },
							{ "slug": "stock", "type": "integer", "label": "Stock" },
							{ "slug": "weight_grams", "type": "integer", "label": "Weight (Grams)" },
							{ "slug": "sku", "type": "string", "label": "SKU" },
							{ "slug": "enabled", "type": "boolean", "label": "Enabled" }
						]
					}
				},
				{
					"slug": "featured_image",
					"label": "Image",
					"type": "image"
				},
				{
					"slug": "excerpt",
					"label": "Short Description",
					"type": "text"
				},
				{
					"slug": "content",
					"label": "Full Description",
					"type": "portableText"
				}
			]
		},
		{
			"slug": "pages",
			"label": "Pages",
			"labelSingular": "Page",
			"supports": ["drafts", "revisions", "search"],
			"fields": [
				{
					"slug": "title",
					"label": "Title",
					"type": "string",
					"required": true,
					"searchable": true
				},
				{
					"slug": "content",
					"label": "Content",
					"type": "portableText",
					"searchable": true
				}
			]
		}
	],

	"taxonomies": [
		{
			"name": "category",
			"label": "Categories",
			"labelSingular": "Category",
			"hierarchical": true,
			"collections": ["posts"],
			"terms": [
				{ "slug": "general", "label": "General" },
				{ "slug": "updates", "label": "Updates" }
			]
		},
		{
			"name": "tag",
			"label": "Tags",
			"labelSingular": "Tag",
			"hierarchical": false,
			"collections": ["posts"],
			"terms": [
				{ "slug": "starter", "label": "Starter" },
				{ "slug": "example", "label": "Example" }
			]
		}
	],

	"menus": [
		{
			"name": "primary",
			"label": "Primary Navigation",
			"items": [
				{ "type": "custom", "label": "Home", "url": "/" },
				{ "type": "custom", "label": "Shop", "url": "/shop" },
				{ "type": "custom", "label": "Posts", "url": "/posts" },
				{ "type": "custom", "label": "About", "url": "/about" }
			]
		}
	],

	"widgetAreas": [
		{
			"name": "sidebar",
			"label": "Sidebar",
			"description": "Sidebar widget area",
			"widgets": [
				{
					"type": "component",
					"componentId": "core:search",
					"title": "Search"
				},
				{
					"type": "component",
					"componentId": "core:categories",
					"title": "Categories"
				},
				{
					"type": "component",
					"componentId": "core:recent-posts",
					"title": "Recent Posts",
					"settings": { "count": 5 }
				}
			]
		},
		{
			"name": "global-top",
			"label": "Global Top",
			"description": "Widgets shown above page content",
			"widgets": []
		},
		{
			"name": "global-bottom",
			"label": "Global Bottom",
			"description": "Widgets shown below page content",
			"widgets": []
		},
		{
			"name": "footer",
			"label": "Footer",
			"description": "Footer widget area",
			"widgets": []
		},
		{
			"name": "home-top",
			"label": "Home Top",
			"description": "Homepage widgets above hero",
			"widgets": []
		},
		{
			"name": "home-before-journal",
			"label": "Home Before Journal",
			"description": "Homepage widgets before latest journal",
			"widgets": [
				{
					"type": "component",
					"componentId": "core:recent-posts",
					"title": "Latest News",
					"settings": { "count": 4 }
				}
			]
		},
		{
			"name": "home-after-journal",
			"label": "Home After Journal",
			"description": "Homepage widgets after latest journal",
			"widgets": []
		},
		{
			"name": "shop-top",
			"label": "Shop Top",
			"description": "Shop widgets before product grid",
			"widgets": []
		},
		{
			"name": "shop-bottom",
			"label": "Shop Bottom",
			"description": "Shop widgets below product grid",
			"widgets": []
		}
	],

	"content": {
		"pages": [
			{
				"id": "about",
				"slug": "about",
				"status": "published",
				"data": {
					"title": "About",
					"content": [
						{
							"_type": "block",
							"style": "normal",
							"children": [
								{
									"_type": "span",
									"text": "This is the about page. Edit it in the admin panel or replace this template with your own design."
								}
							]
						}
					]
				}
			}
		],
		"posts": [
			{
				"id": "post-1",
				"slug": "welcome",
				"status": "published",
				"data": {
					"title": "Welcome",
					"excerpt": "Your first post. Replace this with your own content.",
					"content": [
						{
							"_type": "block",
							"style": "normal",
							"children": [
								{
									"_type": "span",
									"text": "This is a starter post. The templates in this project show the basic patterns for querying and rendering EmDash content. Replace them with your own design."
								}
							]
						},
						{
							"_type": "block",
							"style": "h2",
							"children": [{ "_type": "span", "text": "What to do next" }]
						},
						{
							"_type": "block",
							"style": "normal",
							"children": [
								{
									"_type": "span",
									"text": "Open the admin panel to add content, or edit the Astro pages in src/pages to change how content is displayed."
								}
							]
						}
					]
				},
				"taxonomies": {
					"category": ["general"],
					"tag": ["starter", "example"]
				}
			}
		]
	}
}
